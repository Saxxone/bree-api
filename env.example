DATABASE_URL=
# Optional: pg Pool size for @prisma/adapter-pg (default 10)
PG_POOL_MAX=
# Must be http(s) for browsers (never a disk path). If unset, defaults to API_BASE_URL + /api/file/media/
FILE_BASE_URL=
# Absolute path where uploads are stored (e.g. /Volumes/ssd/Documents/Projects/media). Defaults to ./media under project root.
MEDIA_STORAGE_PATH=
# Max size per file for POST /api/file/upload (MB). Capped at 1024 server-side.
FILE_MAX_SIZE_MB=
# Max number of files per upload request
FILE_MAX_FILES=
GOOGLE_AUTH_CLIENT_ID=
DEFAULT_PROFILE_IMG=
# Public API origin (no trailing slash). Used in post `mediaPlayback` URLs for video/audio streaming.
API_BASE_URL=
# Video/audio at or below this size (bytes) use direct FILE_BASE_URL; larger use range streaming. Default 26214400 (25 MiB).
VIDEO_DIRECT_PLAYBACK_MAX_BYTES=
# If true, `requiresAuth` is true for direct FILE_BASE_URL media (images + small video/audio). Stream URLs always require auth.
MEDIA_DIRECT_URL_REQUIRES_AUTH=
UI_BASE_URL=
JWT_REFRESH_SECRET=
JWT_SECRET=
REDIS_HOST=
REDIS_PORT=

