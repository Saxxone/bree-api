DATABASE_URL=
# Optional: pg Pool size for @prisma/adapter-pg (default 10)
PG_POOL_MAX=
# Must be http(s) for browsers (never a disk path). If unset, defaults to API_BASE_URL + /api/file/media/
FILE_BASE_URL=
# Absolute path where uploads are stored (e.g. /Volumes/ssd/Documents/Projects/media). Defaults to ./media under project root.
MEDIA_STORAGE_PATH=
# Max size per file for POST /api/file/upload (MB). Capped at 1024 server-side.
FILE_MAX_SIZE_MB=
# Max number of files per upload request
FILE_MAX_FILES=
GOOGLE_AUTH_CLIENT_ID=
DEFAULT_PROFILE_IMG=
# Public API origin (no trailing slash). Used in post `mediaPlayback` URLs for video/audio streaming.
API_BASE_URL=
# Video/audio at or below this size (bytes) use direct FILE_BASE_URL; larger use range streaming. Default 26214400 (25 MiB).
VIDEO_DIRECT_PLAYBACK_MAX_BYTES=
# If true, `requiresAuth` is true for direct FILE_BASE_URL media (images + small video/audio). Stream URLs always require auth.
MEDIA_DIRECT_URL_REQUIRES_AUTH=
UI_BASE_URL=
JWT_REFRESH_SECRET=
JWT_SECRET=
REDIS_HOST=
REDIS_PORT=

# --- Virtual currency (coins) ---
# 10 minor units = 1.0 display coin. Default base rate 20 = 2.0 coins per minute.
COIN_BASE_RATE_MINOR_PER_MIN=20
# Optional: override ffprobe (video metadata / coin pricing). If unset: first `ffprobe` on PATH (e.g. Homebrew), else bundled @ffprobe-installer/ffprobe.
# Apple Silicon Homebrew example: /opt/homebrew/bin/ffprobe
FFPROBE_PATH=
# Optional: override ffmpeg (audio compression). If unset: first `ffmpeg` on PATH (e.g. Homebrew), else bundled @ffmpeg-installer/ffmpeg.
# Apple Silicon Homebrew example: /opt/homebrew/bin/ffmpeg
FFMPEG_PATH=

# Stripe (coin packages via Checkout)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Optional: redirect URLs after Checkout (defaults use UI_BASE_URL)
STRIPE_CHECKOUT_SUCCESS_URL=
STRIPE_CHECKOUT_CANCEL_URL=

# Apple App Store Server API (verify consumable purchases by transactionId)
APPLE_ISSUER_ID=
APPLE_KEY_ID=
# PEM contents or base64 of .p8 (include BEGIN/END lines if PEM)
APPLE_PRIVATE_KEY=
APPLE_BUNDLE_ID=
# Set to true for StoreKit sandbox
APPLE_USE_SANDBOX=false

# Google Play Android Publisher API (service account JSON as a single line)
GOOGLE_PLAY_PACKAGE_NAME=
GOOGLE_PLAY_SERVICE_ACCOUNT_JSON=

# Optional: seed script overrides for CoinPackage store IDs / Stripe prices
# SEED_STRIPE_PRICE_STARTER=
# SEED_APPLE_PRODUCT_STARTER=
# SEED_GOOGLE_SKU_STARTER=

