// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  SUPERADMIN
}

enum FileTranscodeStatus {
  NOT_APPLICABLE
  PENDING
  READY
  FAILED
}

enum FilePlaybackKind {
  PROGRESSIVE
  HLS
}

model User {
  id                        String                     @id @default(uuid())
  email                     String                     @unique
  username                  String                     @unique
  name                      String
  role                      UserRole                   @default(USER)
  bio                       String?                    @db.VarChar(140)
  verified                  Boolean                    @default(false)
  banner                    String?
  img                       String
  password                  String?
  stripeConnectAccountId    String?                    @unique
  stripeConnectChargesEnabled Boolean                  @default(false)
  stripeConnectPayoutsEnabled Boolean                  @default(false)
  posts                     Post[]
  files                     File[]
  likedPosts                Post[]                     @relation("likedPosts")
  bookmarkedPosts           Post[]                     @relation("bookmarkedPosts")
  createdAt                 DateTime                   @default(now())
  updatedAt                 DateTime                   @updatedAt
  deletedAt                 DateTime?
  sentChats                 Chat[]                     @relation("chatSender")
  receivedEnvelopes         ChatEnvelope[]             @relation("chatRecipient")
  Room                      Room?                      @relation(fields: [roomId], references: [id])
  roomId                    String?
  /// Olm per-device identity + prekeys (one row per web/mobile/desktop install).
  devices                   Device[]
  LongPost                  LongPost[]
  AuthToken                 AuthToken[]
  notifications             Notification[]
  pushDevices               PushDevice[]
  coinWallet                CoinWallet?
  coinPurchases             CoinPurchase[]
  postUnlocks               PostUnlock[]
  postWatchHistory          PostWatchHistory[]
}

model Post {
  id                       String           @id @default(uuid())
  text                     String?
  media                    String[]
  mediaTypes               String[]
  published                Boolean?         @default(false)
  author                   User             @relation(fields: [authorId], references: [id])
  authorId                 String
  likedBy                  User[]           @relation("likedPosts")
  likeCount                Int              @default(0)
  bookmarkedBy             User[]           @relation("bookmarkedPosts")
  bookmarkCount            Int              @default(0)
  parent                   Post?            @relation("comments", fields: [parentId], references: [id])
  parentId                 String?
  comments                 Post[]           @relation("comments")
  commentCount             Int              @default(0)
  createdAt                DateTime         @default(now())
  updatedAt                DateTime         @updatedAt
  deletedAt                DateTime?
  type                     PostType         @default(SHORT)
  longPost                 LongPost?        @relation(fields: [longPostId], references: [id])
  longPostId               String?
  monetizationEnabled      Boolean          @default(false)
  /// Total duration of attached videos (seconds), derived from uploaded file probes when monetized.
  videoDurationSeconds     Int?
  videoCategory            VideoCategory?
  productionTier           ProductionTier   @default(STANDARD)
  /// Override default COIN_BASE_RATE_MINOR_PER_MIN when set.
  baseRateMinorPerMinute   Int?
  /// Inferred from uploaded video resolution (max across assets). Used for the single fixed viewer price.
  sourceStreamQuality      StreamQuality?
  /// Fixed coin cost (minor units) shown to viewers; set when the post is saved with monetization.
  pricedCostMinor          Int?
  postUnlocks              PostUnlock[]
  watchHistory             PostWatchHistory[]
  /// Optional embedded quote of another published post (not the same as `parentId` / comments).
  quotedPostId             String?
  quotedPost               Post?        @relation("PostQuotedPost", fields: [quotedPostId], references: [id], onDelete: SetNull)
  postsQuotingThis         Post[]       @relation("PostQuotedPost")

  @@index([quotedPostId])
}

model LongPost {
  id        String          @id @default(uuid())
  content   LongPostBlock[]
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
  Post      Post[]
  User      User?           @relation(fields: [userId], references: [id])
  userId    String?
}

model LongPostBlock {
  id         String   @id @default(uuid())
  longPostId String
  longPost   LongPost @relation(fields: [longPostId], references: [id])
  text       String
  media      String[]
  mediaTypes String[]
}

model File {
  id                    String               @id @default(uuid())
  originalname          String
  filename              String
  size                  Int
  type                  String
  url                   String
  /// Local absolute path while on disk; cleared after successful R2 transcode.
  path                  String?
  mimetype              String
  status                Status               @default(PENDING)
  owner                 User                 @relation(fields: [ownerId], references: [id])
  ownerId               String
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  deletedAt             DateTime?
  videoWidth            Int?
  videoHeight           Int?
  videoDurationSeconds  Int?
  trailerFilename       String?
  trailerPath           String?
  trailerUrl            String?
  transcodeStatus       FileTranscodeStatus  @default(NOT_APPLICABLE)
  playbackKind          FilePlaybackKind?
  /// R2 object key for progressive MP4 used by authenticated range streaming.
  r2MainKey             String?
  /// R2 object key for HLS master playlist (relative to bucket; CDN URL = FILE_BASE_URL + key).
  r2ManifestKey         String?
}

/// One logical chat message in a room. Per-recipient ciphertexts live on
/// `ChatEnvelope` (one row per recipient device in an Olm/Double-Ratchet
/// session). The plaintext body is NEVER stored server-side.
model Chat {
  id             String         @id @default(uuid())
  room           Room           @relation(fields: [roomId], references: [id])
  roomId         String
  /// User who authored the message (useful for inbox previews / authz).
  sender         User           @relation("chatSender", fields: [senderUserId], references: [id])
  senderUserId   String
  /// Device that authored the message (used by recipients to look up the
  /// right Olm session on their side).
  senderDevice   Device         @relation("chatSenderDevice", fields: [senderDeviceId], references: [id])
  senderDeviceId String
  createdAt      DateTime       @default(now())
  deletedAt      DateTime?
  envelopes      ChatEnvelope[]

  // History pagination filters by `roomId` and orders by `createdAt desc`.
  @@index([roomId, createdAt])
  @@index([senderDeviceId])
}

/// Per-recipient-device wrapped ciphertext for a `Chat`. Messages fan out
/// to every active device of every room participant (including the sender's
/// other devices so their own history replicates across devices).
model ChatEnvelope {
  id                String   @id @default(uuid())
  chat              Chat     @relation(fields: [chatId], references: [id], onDelete: Cascade)
  chatId            String
  recipient         User     @relation("chatRecipient", fields: [recipientUserId], references: [id])
  recipientUserId   String
  recipientDevice   Device   @relation("chatRecipientDevice", fields: [recipientDeviceId], references: [id], onDelete: Cascade)
  recipientDeviceId String
  /// Olm PreKeyMessage (type=0) or Message (type=1), base64.
  ciphertext        String   @db.Text
  /// 0 = PreKeyMessage (session bootstrap), 1 = Message (ratchet continuation).
  messageType       Int      @default(1)
  /// Unread bookkeeping for the recipient device.
  read              Boolean  @default(false)
  /// Set when the recipient device has acked delivery.
  deliveredAt       DateTime?
  createdAt         DateTime @default(now())

  @@unique([chatId, recipientDeviceId])
  @@index([recipientDeviceId, read])
  @@index([recipientUserId, createdAt])
}

model Room {
  id           String   @id @default(uuid())
  chats        Chat[]
  participants User[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  roomType     RoomType @default(PRIVATE)
}

/// An Olm-capable endpoint (one web tab group, one mobile install, etc.).
/// Identity keys live on the device; the server only stores public material.
model Device {
  id                      String              @id @default(uuid())
  user                    User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId                  String
  /// Human-readable label the user sees in a security/devices screen.
  label                   String
  /// Curve25519 device identity key (base64, 32B raw) — used as peer
  /// identifier when establishing Olm sessions.
  identityKeyCurve25519   String
  /// Ed25519 device identity key (base64, 32B raw) — signs OTKs and is the
  /// device fingerprint shown for out-of-band verification.
  identityKeyEd25519      String               @unique
  oneTimeKeys             DeviceOneTimeKey[]
  fallbackKeys            DeviceFallbackKey[]
  sentChats               Chat[]               @relation("chatSenderDevice")
  receivedEnvelopes       ChatEnvelope[]       @relation("chatRecipientDevice")
  createdAt               DateTime             @default(now())
  updatedAt               DateTime             @updatedAt
  lastSeenAt              DateTime             @default(now())
  /// Set when the user (or admin) revokes the device. Revoked devices stop
  /// receiving new envelopes but previously-delivered messages remain readable
  /// on-disk by that device until it logs out.
  revokedAt               DateTime?

  @@index([userId, revokedAt])
}

/// One-time prekeys uploaded by a `Device`, consumed at most once to bootstrap
/// new Olm sessions from peers. Clients replenish this pool in the background.
model DeviceOneTimeKey {
  id         String    @id @default(uuid())
  device     Device    @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  deviceId   String
  /// Olm-assigned key id, unique within a device (e.g. "AAAAAQ").
  keyId      String
  /// Curve25519 public key (base64, 32B raw).
  publicKey  String
  /// Ed25519 signature over `publicKey` by the device's identity key.
  signature  String
  /// Null while available; set atomically when claimed by a peer.
  claimedAt  DateTime?
  createdAt  DateTime  @default(now())

  @@unique([deviceId, keyId])
  @@index([deviceId, claimedAt])
}

/// Long-lived "fallback" prekey used when a device's one-time-key pool is
/// empty. Exactly one row per device should have `retiredAt` null at a time;
/// old fallback keys are retained (not deleted) so in-flight PreKeyMessages
/// can still establish a session.
model DeviceFallbackKey {
  id         String    @id @default(uuid())
  device     Device    @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  deviceId   String
  keyId      String
  publicKey  String
  signature  String
  createdAt  DateTime  @default(now())
  retiredAt  DateTime?

  @@unique([deviceId, keyId])
  @@index([deviceId, retiredAt])
}

enum Status {
  PENDING
  APPROVED
  REJECTED
  UPLOADED
  DELETED
  SENT
  DELIVERED
  SEEN
}

enum RoomType {
  PRIVATE
  PUBLIC
}

enum PostType {
  LONG
  SHORT
}

model AuthToken {
  id             String   @id @default(uuid())
  userId         String
  user           User     @relation(fields: [userId], references: [id])
  token          String   @unique
  expiresAt      DateTime
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  isRefreshToken Boolean  @default(false)

  @@unique([userId, isRefreshToken])
}

model Notification {
  id              String           @id @default(uuid())
  user            User             @relation(fields: [userId], references: [id])
  userId          String
  type            NotificationType
  description         String
  read            Boolean          @default(false)
  postId          String?
  commentId       String?
  mentionedUserId String?
  /// Room reference for NotificationType.MESSAGE so push deep links can jump straight to the thread.
  roomId          String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model PushDevice {
  id             String   @id @default(uuid())
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId         String
  expoPushToken  String   @unique
  platform       String   @default("unknown")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([userId])
}

enum NotificationType {
  POST_CREATED
  POST_LIKED
  COMMENT_ADDED
  USER_MENTIONED
  MESSAGE
}

enum VideoCategory {
  ENTERTAINMENT
  EDUCATIONAL_DIY
  LIVE_EVENT
}

enum StreamQuality {
  P720
  P1080
  P4K
}

enum ProductionTier {
  STANDARD
  PRO
}

enum CoinTxnType {
  PURCHASE_STRIPE
  PURCHASE_APPLE
  PURCHASE_GOOGLE
  SPEND_UNLOCK
  CREATOR_EARN
  ADJUSTMENT
  /// Negative amountMinor: coins redeemed for cash via Stripe Connect transfer.
  PAYOUT
}

enum CoinPurchaseProvider {
  STRIPE
  APPLE
  GOOGLE
}

enum CoinPurchaseStatus {
  PENDING
  COMPLETED
  FAILED
}

model CoinWallet {
  id             String            @id @default(uuid())
  userId         String            @unique
  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  balanceMinor   Int               @default(0)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  ledgerEntries  CoinLedgerEntry[]
}

model CoinLedgerEntry {
  id                String       @id @default(uuid())
  walletId          String
  wallet            CoinWallet   @relation(fields: [walletId], references: [id], onDelete: Cascade)
  type              CoinTxnType
  /// Signed: credit positive, debit negative.
  amountMinor       Int
  balanceAfterMinor Int
  idempotencyKey    String       @unique
  metadata          Json?
  createdAt         DateTime     @default(now())
}

model CoinPackage {
  id              String          @id @default(uuid())
  name            String
  coinsMinor      Int
  stripePriceId   String?
  appleProductId  String?
  googleProductId String?
  active          Boolean         @default(true)
  sortOrder       Int             @default(0)
  purchases       CoinPurchase[]
}

model CoinPurchase {
  id         String               @id @default(uuid())
  userId     String
  user       User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  packageId  String
  package    CoinPackage          @relation(fields: [packageId], references: [id], onDelete: Restrict)
  provider   CoinPurchaseProvider
  externalId String
  status     CoinPurchaseStatus   @default(PENDING)
  coinsMinor Int
  createdAt  DateTime             @default(now())

  @@unique([provider, externalId])
}

model PostUnlock {
  id                         String   @id @default(uuid())
  userId                     String
  user                       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  postId                     String
  post                       Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  maxStreamQuality           StreamQuality
  /// Total coins debited from viewer for this post (initial + quality upgrades).
  totalPaidMinor             Int      @default(0)
  /// Cumulative platform share (30%) of totalPaidMinor, for reporting.
  platformFeeAccumulatedMinor Int     @default(0)
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt

  @@unique([userId, postId])
}

model PostWatchHistory {
  id            String   @id @default(uuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  postId        String
  post          Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  lastWatchedAt DateTime @default(now()) @updatedAt

  @@unique([userId, postId])
  @@index([userId, lastWatchedAt])
}
